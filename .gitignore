# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# not for the public repo: copyrighted/imported books (keep public-domain samples in public/samples)
/*.epub
